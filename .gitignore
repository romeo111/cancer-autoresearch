/tmp/
*_temp.json
*_draft.json

# Private patient deliverables — CHARTER §9.3
# Keep out until informed consent + de-identification + ethics approval.
# Pattern matches anywhere in the tree (not just root) so files moved
# into infograph/, patient_plans/, etc. stay protected.
**план лікування.html
# Note: infograph/MDT.png, infograph/MDT-light.png, infograph/терапія.png are
# generic project infographics (NOT patient-specific) and intentionally tracked
# — they render on the public landing.

# Knowledge base: live-API query cache (not source of truth, never commit)
knowledge_base/cache/
knowledge_base/**/_fetch_log.json

# Raw downloaded source files — input to ingestion loaders, not committed
# (parsed YAML output under knowledge_base/hosted/ is what we keep)
downloads/

# МОЗ / НСЗУ raw PDFs and CSVs — large binary mirrors of public Ukrainian
# government documents. We reference them by URL in Source entities and
# parse them into structured KB content; raw artifacts stay local. Path
# created by scripts/download_moz_protocols.sh or manual curl.
legacy/source_pdfs/

# Patient plan persistence — per CHARTER §9.3, patient-specific Plan /
# DiagnosticPlan instances live OUTSIDE public KB. Persistence layer
# (knowledge_base/engine/persistence.py) writes here by default.
patient_plans/
.tmp/

# Claude Code local state — per-machine settings, scheduled-task locks,
# and agent worktree scratch dirs. Never commit. (scheduled_tasks.lock
# was tracked historically; leave it tracked but ignore future churn.)
.claude/settings.local.json
.claude/worktrees/
